generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum Role {
  ADMIN
  PLAYER
}

enum CourtStatus {
  AVAILABLE
  MAINTENANCE
  INACTIVE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
}

enum MatchStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String
  phone         String?
  passwordHash  String
  role          Role      @default(PLAYER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  bookings      Booking[]
  payments      Payment[]
  participants  TournamentParticipant[]
}

model Court {
  id          String      @id @default(uuid())
  name        String
  type        String      // ej: Padel, Tenis, Futbol 5
  status      CourtStatus @default(AVAILABLE)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  bookings    Booking[]
}

model Booking {
  id          String        @id @default(uuid())
  userId      String
  courtId     String
  startTime   DateTime
  endTime     DateTime
  status      BookingStatus @default(PENDING)
  totalPrice  Decimal       @db.Decimal(10, 2)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user        User          @relation(fields: [userId], references: [id])
  court       Court         @relation(fields: [courtId], references: [id])
  payment     Payment?
}

model Payment {
  id              String        @id @default(uuid())
  bookingId       String?       @unique
  userId          String
  amount          Decimal       @db.Decimal(10, 2)
  status          PaymentStatus @default(PENDING)
  mpPreferenceId  String?       @unique
  mpPaymentId     String?       @unique // ID del Webhook
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  booking         Booking?      @relation(fields: [bookingId], references: [id])
  user            User          @relation(fields: [userId], references: [id])
}

model Tournament {
  id          String      @id @default(uuid())
  name        String
  startDate   DateTime
  endDate     DateTime?
  status      String      // DRAFT, REGISTRATION, ACTIVE, COMPLETED
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  categories  Category[]
}

model Category {
  id            String      @id @default(uuid())
  tournamentId  String
  name          String      // ej: 1ra, 2da, 3ra, Libres
  level         Int         // Para ordenar/clasificar

  tournament    Tournament  @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  participants  TournamentParticipant[]
  matches       Match[]
}

model TournamentParticipant {
  id          String      @id @default(uuid())
  userId      String
  categoryId  String
  status      String      // PENDING_PAYMENT, CONFIRMED
  joinedAt    DateTime    @default(now())

  user        User        @relation(fields: [userId], references: [id])
  category    Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}

model Match {
  id          String      @id @default(uuid())
  categoryId  String
  round       Int         // ej: 1 (Octavos), 2 (Cuartos), 3 (Semi), 4 (Final)
  player1Id   String?     // Puede ser null si pasa directo por bye
  player2Id   String?
  score1      Int?
  score2      Int?
  winnerId    String?
  status      MatchStatus @default(SCHEDULED)
  courtId     String?     // Cancha asignada (opcional)
  matchTime   DateTime?   // Horario asignado (opcional)

  category    Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}

model Expense {
  id          String    @id @default(uuid())
  description String
  amount      Decimal   @db.Decimal(10, 2)
  date        DateTime  @default(now())
  category    String    // ej: Mantenimiento, Servicios, Sueldos
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Settings {
  key         String    @id
  value       String    @db.Text
  updatedAt   DateTime  @updatedAt
}
